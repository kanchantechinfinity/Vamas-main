{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% comment %} ── Hero Slider ──────────────────────── {% endcomment %}
<div class="vamas-slider" id="vamas-slider">
  <div class="vamas-slider__track" id="vamas-track">

    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        <div class="vamas-slide vamas-slide--{{ block.settings.text_align | default: 'left' }}" style="background: {{ block.settings.slide_bg | default: '#420001' }};">
          {% if block.settings.video != blank %}
            <video class="vamas-slide__bg" autoplay muted loop playsinline preload="metadata"{% if block.settings.slide_image != blank %} poster="{{ block.settings.slide_image | img_url: '1800x760', crop: 'center' }}"{% endif %}>
              {% for source in block.settings.video.sources %}<source src="{{ source.url }}" type="{{ source.mime_type }}">{% endfor %}
            </video>
          {% elsif block.settings.video_url != blank %}
            <div class="vamas-slide__bg vamas-video-embed">
              {% if block.settings.video_url.type == 'youtube' %}
                <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&showinfo=0&modestbranding=1&rel=0&playsinline=1" title="{{ block.settings.line1 | escape }}" allow="autoplay; encrypted-media" frameborder="0"></iframe>
              {% elsif block.settings.video_url.type == 'vimeo' %}
                <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1" title="{{ block.settings.line1 | escape }}" allow="autoplay" frameborder="0"></iframe>
              {% endif %}
            </div>
          {% elsif block.settings.slide_image != blank %}
            <img class="vamas-slide__bg" src="{{ block.settings.slide_image | img_url: '1800x760', crop: 'center' }}"
                 alt="{{ block.settings.slide_image.alt | escape | default: block.settings.line1 }}"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          {% elsif block.settings.image_asset != blank %}
            <img class="vamas-slide__bg" src="{{ block.settings.image_asset | asset_url }}"
                 alt="{{ block.settings.line1 | escape }}"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          {% endif %}
          <div class="vamas-slide__scrim"></div>
          <div class="vamas-slide__inner">
            <div class="vamas-slide__text">
              {% if block.settings.eyebrow != blank %}<p class="vamas-slide__eyebrow">{{ block.settings.eyebrow }}</p>{% endif %}
              <h1 class="vamas-slide__heading">
                {{ block.settings.line1 }}{% if block.settings.line2_accent != blank %} <em>{{ block.settings.line2_accent }}</em>{% endif %}{% if block.settings.line3 != blank %} {{ block.settings.line3 }}{% endif %}
              </h1>
              {% if block.settings.offer != blank %}<div class="vamas-slide__offer">{{ block.settings.offer }}</div>{% endif %}
              {% if block.settings.coupon != blank %}<div class="vamas-slide__coupon">WITH COUPON <span>{{ block.settings.coupon }}</span></div>{% endif %}
              {% if block.settings.subtext != blank %}<p class="vamas-slide__sub">{{ block.settings.subtext }}</p>{% endif %}
              <div class="vamas-slide__btns">
                {% if block.settings.btn1_text != blank %}<a href="{{ block.settings.btn1_url | default: '/collections/all' }}" class="btn-primary">{{ block.settings.btn1_text }}</a>{% endif %}
                {% if block.settings.btn2_text != blank %}<a href="{{ block.settings.btn2_url | default: '/collections/all' }}" class="btn-outline">{{ block.settings.btn2_text }}</a>{% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>

  {% assign slide_count = 0 %}
  {% for block in section.blocks %}{% if block.type == 'slide' %}{% assign slide_count = slide_count | plus: 1 %}{% endif %}{% endfor %}

  {% if slide_count > 1 %}
    <button class="vamas-slider__arrow vamas-slider__arrow--prev" id="vamas-prev" aria-label="Previous slide">&#8592;</button>
    <button class="vamas-slider__arrow vamas-slider__arrow--next" id="vamas-next" aria-label="Next slide">&#8594;</button>
    <div class="vamas-slider__dots" id="vamas-dots">
      {% assign idx = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <button class="vamas-slider__dot {% if idx == 0 %}active{% endif %}"
                  data-idx="{{ idx }}" aria-label="Slide {{ idx | plus: 1 }}"></button>
          {% assign idx = idx | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
(function(){
  var track = document.getElementById('vamas-track');
  var dots  = document.querySelectorAll('#vamas-dots .vamas-slider__dot');
  var cur   = 0;
  var total = dots.length;
  var timer;
  if(!track || total < 2) return;

  function goTo(i){
    cur = (i + total) % total;
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    dots.forEach(function(d,j){ d.classList.toggle('active', j === cur); });
  }

  function reset(){ clearInterval(timer); timer = setInterval(function(){ goTo(cur+1); }, 5000); }

  var prev = document.getElementById('vamas-prev');
  var next = document.getElementById('vamas-next');
  if(prev) prev.addEventListener('click', function(){ goTo(cur-1); reset(); });
  if(next) next.addEventListener('click', function(){ goTo(cur+1); reset(); });
  dots.forEach(function(d){ d.addEventListener('click', function(){ goTo(+this.dataset.idx); reset(); }); });
  reset();
})();
</script>

