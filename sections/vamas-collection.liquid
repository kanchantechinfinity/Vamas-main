{{ 'vamas-collection.css' | asset_url | stylesheet_tag }}

{%- comment -%} On the /collections list page there is no single collection — show all products {%- endcomment -%}
{%- unless collection and collection.products_count > 0 -%}
  {%- assign collection = collections.all -%}
{%- endunless -%}

<section class="col-hero">
  <div class="col-hero-left">
    <div class="col-hero-breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>&gt;</span>
      <span style="color:rgba(231,209,166,.75);">{{ collection.title }}</span>
    </div>
    <h1 class="col-hero-title">{{ collection.title }}</h1>
    <p class="col-hero-sub">{{ section.settings.hero_subtitle | default: collection.description | strip_html | default: 'Handcrafted designs celebrating Indian artistry' }}</p>
  </div>
  {% if section.settings.show_hero_motif %}
  <div class="col-hero-right">
    <svg width="320" height="200" viewBox="0 0 320 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="80" cy="100" rx="40" ry="60" stroke="#e7d1a6" stroke-width="1.5" fill="none" transform="rotate(-20 80 100)"/>
      <ellipse cx="80" cy="100" rx="24" ry="40" stroke="#e7d1a6" stroke-width="1" fill="none" transform="rotate(-20 80 100)"/>
      <circle cx="80" cy="68" r="8" stroke="#e7d1a6" stroke-width="1.2" fill="none"/>
      <circle cx="80" cy="68" r="3" fill="#e7d1a6" opacity=".4"/>
      <ellipse cx="200" cy="80" rx="35" ry="52" stroke="#e7d1a6" stroke-width="1.5" fill="none" transform="rotate(15 200 80)"/>
      <ellipse cx="200" cy="80" rx="20" ry="34" stroke="#e7d1a6" stroke-width="1" fill="none" transform="rotate(15 200 80)"/>
      <circle cx="215" cy="50" r="7" stroke="#e7d1a6" stroke-width="1.2" fill="none"/>
      <circle cx="160" cy="110" r="18" stroke="#e7d1a6" stroke-width="1.2" fill="none" opacity=".5"/>
      <circle cx="160" cy="110" r="8" stroke="#c9a96e" stroke-width="1" fill="none" opacity=".5"/>
      <circle cx="160" cy="110" r="3" fill="#e7d1a6" opacity=".4"/>
    </svg>
  </div>
  {% endif %}
</section>

<div class="mob-filter-bar">
  <button class="mob-filter-btn" id="mob-filter-open" type="button">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    Filters
  </button>
  <div class="filter-chips" id="mob-chips" style="margin:0;"></div>
</div>

<div class="col-body">

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-head">
      <h3>FILTERS</h3>
      <a href="/collections/{{ collection.handle | default: 'all' }}" class="clear-all">Clear All</a>
    </div>

    {% comment %} Tag-based filters (Occasion / Fabric / Color) — filter natively via the collection URL {% endcomment %}
    {% assign vtag_occasion = "Bridal,Festive,Casual,Party Wear" | split: "," %}
    {% assign vtag_fabric = "Silk,Cotton,Velvet,Georgette,Banarasi" | split: "," %}
    <div class="acc-item">
      <div class="acc-head open" onclick="toggleAcc(this)"><span>OCCASION</span><span class="acc-arrow">&#9660;</span></div>
      <div class="acc-body open">
        {% for t in vtag_occasion %}
          <label class="filter-check-row"><input type="checkbox" class="vtag-filter" value="{{ t }}" {% if collection.current_tags contains t %}checked{% endif %}> {{ t }}</label>
        {% endfor %}
      </div>
    </div>
    <div class="acc-item">
      <div class="acc-head open" onclick="toggleAcc(this)"><span>FABRIC</span><span class="acc-arrow">&#9660;</span></div>
      <div class="acc-body open">
        {% for t in vtag_fabric %}
          <label class="filter-check-row"><input type="checkbox" class="vtag-filter" value="{{ t }}" {% if collection.current_tags contains t %}checked{% endif %}> {{ t }}</label>
        {% endfor %}
      </div>
    </div>
    <div class="acc-item">
      <div class="acc-head open" onclick="toggleAcc(this)"><span>COLOR</span><span class="acc-arrow">&#9660;</span></div>
      <div class="acc-body open">
        <div class="color-dots">
          <label><input type="checkbox" class="vtag-filter" value="Maroon" {% if collection.current_tags contains 'Maroon' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#420001;" title="Maroon" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
          <label><input type="checkbox" class="vtag-filter" value="Gold" {% if collection.current_tags contains 'Gold' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#c9a96e;" title="Gold" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
          <label><input type="checkbox" class="vtag-filter" value="Green" {% if collection.current_tags contains 'Green' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#2e7d32;" title="Green" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
          <label><input type="checkbox" class="vtag-filter" value="Navy" {% if collection.current_tags contains 'Navy' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#1a237e;" title="Navy" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
          <label><input type="checkbox" class="vtag-filter" value="White" {% if collection.current_tags contains 'White' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#f5f5f5;border:1.5px solid #ccc;" title="White" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
          <label><input type="checkbox" class="vtag-filter" value="Pink" {% if collection.current_tags contains 'Pink' %}checked{% endif %} style="display:none;"><div class="c-dot" style="background:#e91e8c;" title="Pink" onclick="var i=this.previousElementSibling;i.checked=!i.checked;this.classList.toggle('active');"></div></label>
        </div>
      </div>
    </div>
    <div class="sidebar-apply">
      <button type="button" class="btn-primary" style="width:100%;" id="vtag-apply">APPLY FILTERS</button>
    </div>

    <form method="get">
    {% if collection.sort_by != blank %}<input type="hidden" name="sort_by" value="{{ collection.sort_by }}">{% endif %}

    {% comment %} Price range first — shown above Tags / Availability {% endcomment %}
    {% for filter in collection.filters %}
      {% if filter.type != 'price_range' %}{% continue %}{% endif %}
      <div class="acc-item">
        <div class="acc-head open" onclick="toggleAcc(this)">
          <span>{{ filter.label | upcase }}</span>
          <span class="acc-arrow">&#9660;</span>
        </div>
        <div class="acc-body open">
          <div class="price-range">
            <div class="price-labels">
              <span id="priceMin">{{ filter.min_value.value | default: filter.range_min | money }}</span>
              <span id="priceMax">{{ filter.max_value.value | default: filter.range_max | money }}</span>
            </div>
            <div class="price-track">
              <div class="price-fill" id="priceFill"></div>
              <div class="price-thumb price-thumb-l" id="thumbL"></div>
              <div class="price-thumb price-thumb-r" id="thumbR"></div>
            </div>
            <input type="range" id="rangeMin" name="{{ filter.min_value.param_name }}" min="{{ filter.range_min | divided_by: 100 }}" max="{{ filter.range_max | divided_by: 100 }}" value="{{ filter.min_value.value | default: filter.range_min | divided_by: 100 }}" onchange="this.form.submit()">
            <input type="range" id="rangeMax" name="{{ filter.max_value.param_name }}" min="{{ filter.range_min | divided_by: 100 }}" max="{{ filter.range_max | divided_by: 100 }}" value="{{ filter.max_value.value | default: filter.range_max | divided_by: 100 }}" onchange="this.form.submit()">
          </div>
        </div>
      </div>
    {% endfor %}

    {% comment %} Then the remaining filters (Tags, Availability, …) — Color and Price already handled above {% endcomment %}
    {% for filter in collection.filters %}
      {% if filter.type == 'price_range' %}{% continue %}{% endif %}
      {% if filter.label contains 'olor' %}{% continue %}{% endif %}
      <div class="acc-item">
        <div class="acc-head open" onclick="toggleAcc(this)">
          <span>{{ filter.label | upcase }}</span>
          <span class="acc-arrow">&#9660;</span>
        </div>
        <div class="acc-body open">
          {% for value in filter.values %}
            <label class="filter-check-row">
              <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} onchange="this.form.submit()">
              {{ value.label }} ({{ value.count }})
            </label>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
    </form>
  </aside>

  <div class="prod-area">
    {% paginate collection.products by section.settings.products_per_page %}
    <div class="prod-topbar">
      <div class="prod-count">Showing <strong>{{ paginate.current_offset | plus: 1 }}-{{ paginate.current_offset | plus: collection.products.size }}</strong> of <strong>{{ collection.products_count }}</strong> products</div>
      <div class="sort-wrap">
        <span class="sort-label">SORT BY</span>
        <form method="get">
        {% for filter in collection.filters %}
          {% for value in filter.active_values %}<input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">{% endfor %}
          {% if filter.min_value.value %}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">{% endif %}
          {% if filter.max_value.value %}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">{% endif %}
        {% endfor %}
        <select class="sort-sel" name="sort_by" onchange="this.form.submit()">
          {% for option in collection.sort_options %}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
          {% endfor %}
        </select>
        </form>
      </div>
    </div>

    {% if collection.filters.size > 0 %}
    <div class="filter-chips" id="chip-container">
      {% for filter in collection.filters %}
        {% for value in filter.values %}
          {% if value.active %}
            <a href="{{ value.url_to_remove }}" class="f-chip">{{ value.label }}<span class="x"></span></a>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
    {% endif %}

    <div class="prod-grid">
      {% for product in collection.products %}
        {% render 'vamas-product-card', product: product %}
      {% else %}
        <p>No products found in this collection.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
    <div class="pagination">
      {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="page-btn">&#8592; Previous</a>{% else %}<span class="page-btn disabled">&#8592; Previous</span>{% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}<a href="{{ part.url }}" class="page-btn">{{ part.title }}</a>{% else %}<span class="page-btn{% if part.title == paginate.current_page %} active{% endif %}">{{ part.title }}</span>{% endif %}
      {% endfor %}
      {% if paginate.next %}<a href="{{ paginate.next.url }}" class="page-btn">Next &#8594;</a>{% else %}<span class="page-btn disabled">Next &#8594;</span>{% endif %}
    </div>
    {% endif %}
    {% endpaginate %}
  </div>
</div>

<script>
function toggleAcc(head){
  head.classList.toggle('open');
  var body = head.nextElementSibling;
  body.classList.toggle('open');
}
document.getElementById('mob-filter-open') && document.getElementById('mob-filter-open').addEventListener('click', function(){
  document.getElementById('sidebar').classList.toggle('mob-open');
});
(function(){
  var apply = document.getElementById('vtag-apply');
  if(!apply) return;
  apply.addEventListener('click', function(){
    var tags = [];
    document.querySelectorAll('.vtag-filter:checked').forEach(function(cb){ tags.push(cb.value.trim().toLowerCase().replace(/\s+/g,'-')); });
    var base = '/collections/{{ collection.handle | default: "all" }}';
    window.location.href = tags.length ? (base + '/' + tags.join('+')) : base;
  });
})();
</script>

{% schema %}
{
  "name": "Vamas Collection",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 4, "max": 48, "step": 4, "label": "Products Per Page", "default": 12 },
    { "type": "textarea", "id": "hero_subtitle", "label": "Hero Subtitle (overrides collection description)" },
    { "type": "checkbox", "id": "show_hero_motif", "label": "Show Decorative Motif", "default": true }
  ],
  "presets": [{ "name": "Vamas Collection" }]
}
{% endschema %}
