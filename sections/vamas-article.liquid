{% assign words = article.content | strip_html | number_of_words %}
{% assign read_min = words | divided_by: 200 | plus: 1 %}

{%- comment -%} Pull-quote source {%- endcomment -%}
{%- if section.settings.pull_quote != blank -%}
  {%- assign pull_quote = section.settings.pull_quote -%}
{%- elsif article.excerpt != blank -%}
  {%- assign pull_quote = article.excerpt | strip_html -%}
{%- else -%}
  {%- assign pull_quote = article.content | strip_html | truncatewords: 24 -%}
{%- endif -%}

{%- comment -%} Featured collection {%- endcomment -%}
{%- if section.settings.featured_collection != blank and collections[section.settings.featured_collection] != empty -%}
  {%- assign feat_collection = collections[section.settings.featured_collection] -%}
{%- else -%}
  {%- assign feat_collection = collections.all -%}
{%- endif -%}

<style>
  .va-wrap {
    background: var(--color-bg, #fff9f2);
    padding: 40px var(--page-gutter, 48px) 80px;
  }
  .varticle {
    display: flex;
    gap: 56px;
    align-items: flex-start;
    max-width: 1340px;
    margin: 0 auto;
  }
  .va-main { flex: 1; min-width: 0; }
  .va-side {
    width: 360px;
    flex-shrink: 0;
    position: -webkit-sticky;
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    /* hide scrollbar (still scrollable) */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .va-side::-webkit-scrollbar { width: 0; height: 0; display: none; }

  /* Hero */
  .va-hero-wrap {
    position: relative;
    height: auto;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 32px;
  }
  .va-hero {
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  /* Title / meta */
  .va-title {
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    font-size: 40px;
    line-height: 1.12;
    margin: 0 0 14px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .va-meta {
    font-family: var(--font-body);
    color: var(--color-maroon-light, #6b2b26);
    font-size: 14px;
    letter-spacing: .4px;
    margin-bottom: 34px;
    opacity: .9;
  }

  /* Pull quote */
  .va-quote {
    position: relative;
    font-family: var(--font-heading);
    font-style: italic;
    text-align: center;
    color: var(--color-maroon, #420001);
    font-size: 26px;
    line-height: 1.4;
    max-width: 760px;
    margin: 0 auto 40px;
    padding: 24px 48px;
  }
  .va-quote::before,
  .va-quote::after {
    font-family: Georgia, serif;
    color: var(--color-gold-dark, #c9a96e);
    font-size: 72px;
    line-height: 0;
    position: absolute;
  }
  .va-quote::before { content: "\201C"; left: 0; top: 30px; }
  .va-quote::after { content: "\201D"; right: 0; bottom: -8px; }

  /* Body columns */
  .va-body {
    font-family: var(--font-body);
    color: #3a2c26;
    font-size: 16px;
    line-height: 1.75;
    max-width: 760px;
  }
  .va-body p { margin: 0 0 18px; }
  .va-body h2,
  .va-body h3 {
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    break-inside: avoid;
    line-height: 1.2;
  }
  .va-body h2 { font-size: 24px; margin: 26px 0 12px; }
  .va-body h3 { font-size: 19px; margin: 22px 0 10px; }
  .va-body img {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    break-inside: avoid;
    margin: 14px 0;
  }
  .va-body ul,
  .va-body ol { margin: 0 0 18px; padding-left: 22px; }
  .va-body li { margin-bottom: 8px; }
  .va-body a {
    color: var(--color-maroon, #420001);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .va-body a:hover { color: var(--color-gold-dark, #c9a96e); }

  /* Share + tags */
  .va-share-tags {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--color-gold, #e7d1a6);
  }
  .va-share {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
  }
  .va-share-label {
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 12px;
    color: var(--color-maroon, #420001);
    font-weight: 600;
  }
  .va-share a {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid var(--color-gold-dark, #c9a96e);
    border-radius: 20px;
    color: var(--color-maroon, #420001);
    text-decoration: none;
    font-size: 13px;
    transition: all .2s;
  }
  .va-share a:hover {
    background: var(--color-maroon, #420001);
    color: var(--color-gold, #e7d1a6);
    border-color: var(--color-maroon, #420001);
  }
  .va-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .va-tag {
    background: var(--color-gold, #e7d1a6);
    color: var(--color-maroon, #420001);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 12px;
    text-decoration: none;
    font-family: var(--font-body);
    transition: all .2s;
  }
  .va-tag:hover { background: var(--color-gold-dark, #c9a96e); }

  /* Sidebar cards */
  .va-card {
    background: #fff;
    border: 1px solid var(--color-gold, #e7d1a6);
    border-radius: 12px;
    padding: 22px;
    margin-bottom: 24px;
  }
  .va-card-title {
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-gold, #e7d1a6);
  }

  /* Designer */
  .va-designer { text-align: center; }
  .va-avatar-link { display: inline-block; cursor: pointer; text-decoration: none; transition: transform .2s, box-shadow .2s; border-radius: 50%; }
  .va-avatar-link:hover { transform: scale(1.05); }
  .va-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 12px;
    display: block;
    border: 2px solid var(--color-gold-dark, #c9a96e);
  }
  .va-avatar-ph {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    margin: 0 auto 12px;
    background: var(--color-gold, #e7d1a6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    font-size: 30px;
    border: 2px solid var(--color-gold-dark, #c9a96e);
  }
  .va-designer-name {
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    font-size: 17px;
    margin: 0 0 8px;
  }
  .va-designer-text {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: #5a4a42;
    margin: 0;
  }

  /* Featured products */
  .va-prod {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #f0e6d8;
    text-decoration: none;
  }
  .va-prod:last-child { border-bottom: 0; }
  .va-prod img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .va-prod-info { min-width: 0; }
  .va-prod-title {
    font-family: var(--font-body);
    font-size: 13.5px;
    color: var(--color-maroon, #420001);
    line-height: 1.3;
    margin: 0 0 4px;
  }
  .va-prod-price {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-gold-dark, #c9a96e);
    font-weight: 600;
  }

  /* Related reads */
  .va-related { list-style: none; margin: 0; padding: 0; }
  .va-related li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px solid #f0e6d8;
  }
  .va-related li:last-child { border-bottom: 0; }
  .va-rel-num {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-maroon, #420001);
    color: var(--color-gold, #e7d1a6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 13px;
  }
  .va-related a {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-maroon, #420001);
    text-decoration: none;
    line-height: 1.35;
  }
  .va-related a:hover { color: var(--color-gold-dark, #c9a96e); }

  /* You might also like */
  .va-alike { display: flex; flex-direction: column; gap: 14px; }
  .va-alike-card { text-decoration: none; display: block; }
  .va-alike-card img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    margin-bottom: 8px;
    display: block;
  }
  .va-alike-ph {
    width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    border-radius: 8px;
    background: var(--color-gold, #e7d1a6);
    margin-bottom: 8px;
  }
  .va-alike-title {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-maroon, #420001);
    line-height: 1.35;
  }

  @media (max-width: 1024px) {
    .varticle { flex-direction: column; }
    .va-side { width: 100%; position: static; margin-top: 24px; max-height: none; overflow: visible; }
  }
  @media (max-width: 768px) {
    .va-body { column-count: 1; }
    .va-title { font-size: 28px; }
    .va-hero-wrap { height: auto; }
    .va-quote { font-size: 21px; padding: 20px 32px; }
    .va-share-tags { flex-direction: column; align-items: flex-start; }
  }

  /* Table of contents */
  .va-toc {
    background: #fff;
    border: 1px solid var(--color-gold, #e7d1a6);
    border-radius: 12px;
    padding: 20px 24px;
    margin: 0 0 32px;
    max-width: 760px;
  }
  .va-toc-title {
    font-family: var(--font-heading);
    color: var(--color-maroon, #420001);
    font-size: 15px;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }
  .va-toc-list {
    margin: 0;
    padding-left: 22px;
    list-style: disc;
  }
  .va-toc-list > li { color: var(--color-maroon-light, #6b2b26); margin-bottom: 8px; }
  .va-toc-list > li::marker { color: var(--color-gold-dark, #c9a96e); }
  .va-toc-list a {
    color: #3a2c26;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    transition: color .2s;
  }
  .va-toc-list a:hover { color: var(--color-maroon, #420001); text-decoration: underline; }
  .va-toc-list .va-toc-sub { list-style: circle; margin-left: 8px; }

  /* FAQ dropdown in TOC */
  .va-toc-caret { cursor: pointer; margin-left: 6px; font-size: 11px; color: var(--color-gold-dark, #c9a96e); display: inline-block; transition: transform .2s; }
  .va-toc-faq.collapsed .va-toc-caret { transform: rotate(-90deg); }
  .va-toc-sublist { list-style: disc; margin: 8px 0 0 18px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .va-toc-faq.collapsed .va-toc-sublist { display: none; }
  .va-toc-sublist a { color: #6a5b53; font-size: 14px; text-decoration: none; }
  .va-toc-sublist a:hover { color: var(--color-maroon, #420001); text-decoration: underline; }

  /* FAQ dropdowns in the article body */
  .va-faq { border: 1px solid var(--color-gold, #e7d1a6); border-radius: 10px; margin: 0 0 12px; background: #fff; overflow: hidden; }
  .va-faq summary { cursor: pointer; padding: 14px 44px 14px 18px; font-family: var(--font-heading); color: var(--color-maroon, #420001); font-size: 17px; list-style: none; position: relative; }
  .va-faq summary::-webkit-details-marker { display: none; }
  .va-faq summary::after { content: '+'; position: absolute; right: 18px; top: 50%; transform: translateY(-50%); font-size: 22px; color: var(--color-gold-dark, #c9a96e); }
  .va-faq[open] summary::after { content: '\2013'; }
  .va-faq > *:not(summary) { padding: 0 18px; margin: 6px 0; }
  .va-faq > *:not(summary):last-child { padding-bottom: 14px; }
</style>

<div class="va-wrap">
  <div class="varticle">

    <main class="va-main">
      {% if article.image %}
        <div class="va-hero-wrap" style="background-image:url({{ article.image | image_url: width: 1200 }});">
          <img class="va-hero" src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" loading="eager">
        </div>
      {% endif %}

      <h1 class="va-title">{{ article.title }}</h1>

      <div class="va-meta">
        by {{ article.author | default: 'the Vamas Design Team' }} &nbsp;|&nbsp; {{ article.published_at | date: '%B %d, %Y' }} &nbsp;|&nbsp; {{ read_min }} min read
      </div>

      {% if pull_quote != blank %}
        <blockquote class="va-quote">{{ pull_quote }}</blockquote>
      {% endif %}

      {% comment %} Table of contents — auto-built from the article headings {% endcomment %}
      <nav class="va-toc" id="vaToc" hidden aria-label="Table of contents">
        <p class="va-toc-title">Table of Contents</p>
        <ol class="va-toc-list"></ol>
      </nav>

      <div class="va-body rte">
        {{ article.content }}
      </div>

      <div class="va-share-tags">
        <div class="va-share">
          <span class="va-share-label">Share</span>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener">Facebook</a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener">Twitter</a>
          <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&media={{ article.image | image_url: width: 800 }}&description={{ article.title | url_encode }}" target="_blank" rel="noopener">Pinterest</a>
        </div>
        {% if article.tags.size > 0 %}
          <div class="va-tags">
            {% for tag in article.tags %}
              <a class="va-tag" href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </main>

    <aside class="va-side">

      {% comment %} Meet the designer {% endcomment %}
      <div class="va-card va-designer">
        <div class="va-card-title">Meet the Designer</div>
        <a class="va-avatar-link" href="{{ pages.contact.url | default: '/pages/contact' }}" aria-label="Contact us">
        {% if section.settings.designer_image != blank %}
          <img class="va-avatar" src="{{ section.settings.designer_image | image_url: width: 200 }}" alt="{{ section.settings.designer_name | escape }}">
        {% else %}
          <div class="va-avatar-ph">V</div>
        {% endif %}
        </a>
        <div class="va-designer-name">{{ section.settings.designer_name | default: 'The Vamas Design Team' }}</div>
        <p class="va-designer-text">{{ section.settings.designer_text }}</p>
      </div>

      {% comment %} Featured products {% endcomment %}
      {% if feat_collection.products.size > 0 %}
        <div class="va-card">
          <div class="va-card-title">{{ section.settings.featured_heading | default: 'Featured Products' }}</div>
          {% for p in feat_collection.products limit: 3 %}
            <a class="va-prod" href="{{ p.url }}">
              {% if p.featured_image %}
                <img src="{{ p.featured_image | image_url: width: 120 }}" alt="{{ p.title | escape }}">
              {% endif %}
              <div class="va-prod-info">
                <div class="va-prod-title">{{ p.title }}</div>
                <div class="va-prod-price">{{ p.price | money }}</div>
              </div>
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {% comment %} Related reads {% endcomment %}
      {% assign rel_count = 0 %}
      {% capture related_html %}
        {% for a in blog.articles %}
          {% if a.id != article.id and rel_count < 4 %}
            {% assign rel_count = rel_count | plus: 1 %}
            <li>
              <span class="va-rel-num">{{ rel_count }}</span>
              <a href="{{ a.url }}">{{ a.title }}</a>
            </li>
          {% endif %}
        {% endfor %}
      {% endcapture %}
      {% if rel_count > 0 %}
        <div class="va-card">
          <div class="va-card-title">{{ section.settings.related_heading | default: 'Related Reads' }}</div>
          <ol class="va-related">{{ related_html }}</ol>
        </div>
      {% endif %}

      {% comment %} You might also like {% endcomment %}
      {% assign alike_count = 0 %}
      {% capture alike_html %}
        {% for a in blog.articles %}
          {% if a.id != article.id and alike_count < 3 %}
            {% assign alike_count = alike_count | plus: 1 %}
            <a class="va-alike-card" href="{{ a.url }}">
              {% if a.image %}
                <img src="{{ a.image | image_url: width: 400 }}" alt="{{ a.title | escape }}">
              {% else %}
                <div class="va-alike-ph"></div>
              {% endif %}
              <div class="va-alike-title">{{ a.title }}</div>
            </a>
          {% endif %}
        {% endfor %}
      {% endcapture %}
      {% if alike_count > 0 %}
        <div class="va-card">
          <div class="va-card-title">You Might Also Like</div>
          <div class="va-alike">{{ alike_html }}</div>
        </div>
      {% endif %}

    </aside>

  </div>
</div>

<script>
  (function () {
    var body = document.querySelector('.va-body');
    if (!body) return;
    var toc = document.getElementById('vaToc');
    var h2s = body.querySelectorAll('h2');

    function scrollToEl(id) {
      var t = document.getElementById(id);
      if (t) { window.scrollTo({ top: t.getBoundingClientRect().top + window.pageYOffset - 90, behavior: 'smooth' }); }
    }

    var faqHead = null;
    h2s.forEach(function (h) { if (!faqHead && /faq/i.test(h.textContent)) faqHead = h; });

    /* Build TOC from H2 only; FAQ heading gets an expandable sub-list */
    if (toc && h2s.length > 1) {
      var list = toc.querySelector('.va-toc-list');
      h2s.forEach(function (h, i) {
        if (!h.id) { h.id = 'sec-' + (i + 1) + '-' + (h.textContent || '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); }
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + h.id; a.textContent = h.textContent;
        a.addEventListener('click', function (e) {
          e.preventDefault();
          if (h === faqHead && li.classList.contains('va-toc-faq')) {
            li.classList.toggle('collapsed');
          } else {
            scrollToEl(h.id);
          }
        });
        li.appendChild(a);

        if (h === faqHead) {
          var caret = document.createElement('span');
          caret.className = 'va-toc-caret'; caret.textContent = '▾';
          li.appendChild(caret);
          var sub = document.createElement('ul'); sub.className = 'va-toc-sublist';
          var n = faqHead.nextElementSibling, qi = 0;
          while (n && n.tagName !== 'H2') {
            if (n.tagName === 'H3') {
              qi++;
              if (!n.id) { n.id = 'faq-' + qi + '-' + (n.textContent || '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); }
              var sli = document.createElement('li');
              var sa = document.createElement('a');
              sa.href = '#' + n.id; sa.textContent = n.textContent;
              (function (id) { sa.addEventListener('click', function (e) { e.preventDefault(); var d = document.getElementById(id); if (d && d.tagName === 'DETAILS') d.open = true; scrollToEl(id); }); })(n.id);
              sli.appendChild(sa); sub.appendChild(sli);
            }
            n = n.nextElementSibling;
          }
          if (sub.children.length) {
            li.classList.add('va-toc-faq', 'collapsed');
            li.appendChild(sub);
            caret.addEventListener('click', function () { li.classList.toggle('collapsed'); });
          }
        }
        list.appendChild(li);
      });
      toc.hidden = false;
    }

    /* Turn each FAQ question (H3) into a dropdown in the body */
    if (faqHead) {
      var node = faqHead.nextElementSibling;
      while (node && node.tagName !== 'H2') {
        if (node.tagName === 'H3') {
          var details = document.createElement('details');
          details.className = 'va-faq';
          if (node.id) details.id = node.id;
          var summary = document.createElement('summary');
          summary.textContent = node.textContent;
          details.appendChild(summary);
          var ans = node.nextElementSibling;
          while (ans && ans.tagName !== 'H3' && ans.tagName !== 'H2') { var after = ans.nextElementSibling; details.appendChild(ans); ans = after; }
          node.parentNode.replaceChild(details, node);
          node = ans;
        } else { node = node.nextElementSibling; }
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Vamas Article",
  "settings": [
    { "type": "color", "id": "hero_bg_color", "label": "Hero Background Color", "default": "#f0d9be" },
    { "type": "textarea", "id": "pull_quote", "label": "Pull quote" },
    { "type": "text", "id": "designer_name", "label": "Designer name", "default": "The Vamas Design Team" },
    { "type": "image_picker", "id": "designer_image", "label": "Designer image" },
    { "type": "textarea", "id": "designer_text", "label": "Designer text", "default": "The Vamas Design Team shares the thinking behind every blouse — fabric, fit and drape — from our Mumbai atelier." },
