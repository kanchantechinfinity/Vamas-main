{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

<style>
  .about-hero { background: var(--color-maroon); padding: 100px 80px 90px; text-align: center; position: relative; overflow: hidden; }
  .about-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(231,209,166,0.08) 0%, transparent 70%); }
  .about-hero__eye { font-size: 10px; font-weight: 700; letter-spacing: 4px; color: rgba(231,209,166,0.45); margin-bottom: 22px; position: relative; z-index: 1; }
  .about-hero__h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 72px; font-weight: 700; color: var(--color-gold); line-height: 1.1; margin-bottom: 22px; position: relative; z-index: 1; }
  .about-hero__sub { font-size: 15px; font-weight: 300; color: rgba(231,209,166,0.6); max-width: 520px; margin: 0 auto 36px; line-height: 1.7; position: relative; z-index: 1; }
  .about-hero__line { width: 80px; height: 2px; background: linear-gradient(90deg, transparent, var(--color-gold), transparent); margin: 0 auto; position: relative; z-index: 1; }

  .about-story { display: flex; align-items: center; gap: 80px; padding: 96px 80px; background: var(--color-bg); }
  .about-story__text { flex: 1; }
  .about-story__eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 3.5px; color: var(--color-gold-dark); margin-bottom: 18px; }
  .about-story__h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 42px; font-weight: 700; color: var(--color-maroon); line-height: 1.25; margin-bottom: 28px; }
  .about-story__h2 em { font-style: italic; color: var(--color-maroon-light); }
  .about-story__p { font-size: 14px; font-weight: 300; color: rgba(66,0,1,0.65); line-height: 1.9; margin-bottom: 18px; }
  .about-story__img-wrap { flex: 1; border-radius: 16px; overflow: hidden; box-shadow: 0 24px 64px rgba(66,0,1,0.18); max-width: 480px; }
  .about-story__img { width: 100%; height: 520px; object-fit: cover; object-position: center; display: block; }

  .about-stats { background: var(--color-maroon); display: flex; align-items: center; justify-content: center; gap: 0; }
  .about-stats__item { flex: 1; text-align: center; padding: 52px 40px; border-right: 1px solid rgba(231,209,166,0.12); }
  .about-stats__item:last-child { border-right: none; }
  .about-stats__num { font-family: 'Playfair Display', Georgia, serif; font-size: 44px; font-weight: 700; color: var(--color-gold); line-height: 1; margin-bottom: 10px; }
  .about-stats__label { font-size: 11px; font-weight: 600; letter-spacing: 2px; color: rgba(231,209,166,0.45); text-transform: uppercase; }

  .about-values { padding: 96px 80px; background: #fff; text-align: center; }
  .about-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 3.5px; color: var(--color-gold-dark); margin-bottom: 14px; }
  .about-h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 42px; font-weight: 700; color: var(--color-maroon); line-height: 1.25; margin-bottom: 16px; }
  .about-sub { font-size: 14px; font-weight: 300; color: rgba(66,0,1,0.55); max-width: 520px; margin: 0 auto 60px; line-height: 1.8; }
  .about-values__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; max-width: 1040px; margin: 0 auto; }
  .about-val { background: var(--color-bg); border-radius: 16px; padding: 48px 36px; border: 1px solid rgba(231,209,166,0.35); transition: transform 0.25s, box-shadow 0.25s; }
  .about-val:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(66,0,1,0.10); }
  .about-val__icon { width: 64px; height: 64px; border-radius: 50%; background: var(--color-maroon); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; }
  .about-val__icon svg { width: 28px; height: 28px; }
  .about-val__title { font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: var(--color-maroon); margin-bottom: 14px; }
  .about-val__desc { font-size: 13px; font-weight: 300; color: rgba(66,0,1,0.6); line-height: 1.8; }

  .about-team { padding: 96px 80px; background: var(--color-bg); text-align: center; }
  .about-team__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; max-width: 960px; margin: 0 auto; }
  .about-team__card { background: #fff; border-radius: 16px; padding: 40px 28px; border: 1px solid rgba(231,209,166,0.3); transition: transform 0.25s, box-shadow 0.25s; }
  .about-team__card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(66,0,1,0.10); }
  .about-team__avatar { width: 80px; height: 80px; border-radius: 50%; background: var(--color-maroon); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-family: 'Playfair Display', Georgia, serif; font-size: 28px; font-weight: 700; color: var(--color-gold); letter-spacing: 1px; }
  .about-team__name { font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 700; color: var(--color-maroon); margin-bottom: 6px; }
  .about-team__role { font-size: 10px; font-weight: 700; letter-spacing: 2.5px; color: var(--color-gold-dark); margin-bottom: 14px; text-transform: uppercase; }
  .about-team__bio { font-size: 12px; font-weight: 300; color: rgba(66,0,1,0.6); line-height: 1.8; }

  .about-timeline { padding: 96px 80px; background: var(--color-maroon); position: relative; overflow: hidden; }
  .about-timeline::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(231,209,166,0.05) 0%, transparent 70%); }
  .about-timeline .about-eyebrow { color: rgba(231,209,166,0.45); }
  .about-timeline .about-h2 { color: var(--color-gold); }
  .about-timeline .about-sub { color: rgba(231,209,166,0.45); margin-bottom: 72px; }
  .about-tl { position: relative; max-width: 800px; margin: 0 auto; }
  .about-tl::before { content: ''; position: absolute; left: 50%; transform: translateX(-50%); top: 0; bottom: 0; width: 1px; background: rgba(231,209,166,0.15); }
  .about-tl__item { display: flex; align-items: flex-start; gap: 40px; margin-bottom: 52px; position: relative; }
  .about-tl__item:last-child { margin-bottom: 0; }
  .about-tl__item.right { flex-direction: row-reverse; }
  .about-tl__content { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid rgba(231,209,166,0.12); border-radius: 12px; padding: 24px 28px; }
  .about-tl__item.right .about-tl__content { text-align: right; }
  .about-tl__year { font-family: 'Playfair Display', Georgia, serif; font-size: 32px; font-weight: 700; color: var(--color-gold); margin-bottom: 8px; }
  .about-tl__desc { font-size: 13px; font-weight: 300; color: rgba(231,209,166,0.55); line-height: 1.7; }
  .about-tl__dot { position: absolute; left: 50%; transform: translateX(-50%); top: 20px; width: 14px; height: 14px; border-radius: 50%; background: var(--color-gold); border: 3px solid var(--color-maroon); box-shadow: 0 0 0 4px rgba(231,209,166,0.15); z-index: 2; }
  .about-tl__spacer { flex: 1; }

  @media (max-width: 1024px) {
    .about-hero { padding: 80px 48px 72px; }
    .about-hero__h1 { font-size: 56px; }
    .about-story { padding: 72px 48px; gap: 52px; }
    .about-story__h2 { font-size: 34px; }
    .about-values, .about-team, .about-timeline { padding: 72px 48px; }
    .about-values__grid, .about-team__grid { gap: 20px; }
  }
  @media (max-width: 768px) {
    .about-hero { padding: 64px 24px 56px; }
    .about-hero__h1 { font-size: 40px; }
    .about-hero__sub { font-size: 13px; }
    .about-story { flex-direction: column; padding: 52px 20px; gap: 36px; }
    .about-story__img-wrap { max-width: 100%; }
    .about-story__img { height: 320px; }
    .about-story__h2 { font-size: 28px; }
    .about-stats { flex-direction: column; gap: 0; }
    .about-stats__item { border-right: none; border-bottom: 1px solid rgba(231,209,166,0.12); padding: 36px 20px; }
    .about-stats__item:last-child { border-bottom: none; }
    .about-stats__num { font-size: 36px; }
    .about-values, .about-team, .about-timeline { padding: 52px 20px; }
    .about-h2 { font-size: 30px; }
    .about-values__grid { grid-template-columns: 1fr; }
    .about-team__grid { grid-template-columns: 1fr; }
    .about-tl::before { left: 20px; transform: none; }
    .about-tl__item, .about-tl__item.right { flex-direction: row; gap: 20px; }
    .about-tl__item.right .about-tl__content { text-align: left; }
    .about-tl__dot { left: 20px; transform: translateX(-50%); }
    .about-tl__spacer { display: none; }
    .about-tl__content { margin-left: 40px; }
    .about-tl__year { font-size: 24px; }
  }

  /* Timeline scroll reveal (enabled by JS; items stay visible if JS is off) */
  .about-tl.reveal-on .about-tl__item { opacity: 0; transition: opacity 0.6s ease, transform 0.6s ease; will-change: opacity, transform; }
  .about-tl.reveal-on .about-tl__item:not(.right) { transform: translate(-48px, 24px); }
  .about-tl.reveal-on .about-tl__item.right { transform: translate(48px, 24px); }
  .about-tl.reveal-on .about-tl__item.revealed { opacity: 1; transform: none; }
  @media (max-width: 768px) {
    .about-tl.reveal-on .about-tl__item:not(.right),
    .about-tl.reveal-on .about-tl__item.right { transform: translate(0, 24px); }
  }
</style>

{% comment %} ── 1. Hero ─────────────────────────── {% endcomment %}
<section class="about-hero">
  <div class="about-hero__eye">{{ section.settings.hero_eyebrow }}</div>
  <h1 class="about-hero__h1">{{ section.settings.hero_heading }}</h1>
  <p class="about-hero__sub">{{ section.settings.hero_sub }}</p>
  <div class="about-hero__line"></div>
</section>

{% comment %} ── 2. Brand Story ──────────────────── {% endcomment %}
<section class="about-story">
  <div class="about-story__text">
    <div class="about-story__eyebrow">{{ section.settings.story_eyebrow }}</div>
    <h2 class="about-story__h2">{{ section.settings.story_heading }}</h2>
    <div class="about-story__p">{{ section.settings.story_body }}</div>
  </div>
  <div class="about-story__img-wrap">
    {% if section.settings.story_image != blank %}
      <img src="{{ section.settings.story_image | img_url: '480x520', crop: 'center' }}" alt="Vamas handcrafted blouse" class="about-story__img" loading="lazy" width="480" height="520">
    {% elsif section.settings.story_image_asset != blank %}
      <img src="{{ section.settings.story_image_asset | asset_url }}" alt="Vamas handcrafted blouse" class="about-story__img" loading="lazy" width="480" height="520">
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg about-story__img' }}
    {% endif %}
  </div>
</section>

{% comment %} ── 3. Stats Bar ────────────────────── {% endcomment %}
{% assign stat_blocks = section.blocks | where: 'type', 'stat' %}
{% if stat_blocks.size > 0 %}
<div class="about-stats">
  {% for block in section.blocks %}
    {% if block.type == 'stat' %}
      <div class="about-stats__item" {{ block.shopify_attributes }}>
        <div class="about-stats__num">{{ block.settings.stat_num }}</div>
        <div class="about-stats__label">{{ block.settings.stat_label }}</div>
      </div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{% comment %} ── 4. Our Values ───────────────────── {% endcomment %}
{% assign value_blocks = section.blocks | where: 'type', 'value' %}
{% if value_blocks.size > 0 %}
<section class="about-values">
  <div class="about-eyebrow">{{ section.settings.values_eyebrow }}</div>
  <h2 class="about-h2">{{ section.settings.values_heading }}</h2>
  <p class="about-sub">{{ section.settings.values_sub }}</p>
  <div class="about-values__grid">
    {% for block in section.blocks %}
      {% if block.type == 'value' %}
        <div class="about-val" {{ block.shopify_attributes }}>
          <div class="about-val__icon">
            {% case block.settings.icon %}
              {% when 'craft' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ settings.color_gold | default: '#e7d1a6' }}" stroke-width="1.8"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% when 'sustain' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ settings.color_gold | default: '#e7d1a6' }}" stroke-width="1.8"><path d="M2 22l10-10m0 0l4-4m-4 4L6 6m6 6l4 4m0-14s4 0 4 4-4 4-4 4"/><circle cx="12" cy="7" r="3"/><path d="M20 14s-2 4-8 4-8-4-8-4"/></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ settings.color_gold | default: '#e7d1a6' }}" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {% endcase %}
          </div>
          <div class="about-val__title">{{ block.settings.title }}</div>
          <div class="about-val__desc">{{ block.settings.desc }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% comment %} ── 5. Meet Our Team ────────────────── {% endcomment %}
{% assign team_blocks = section.blocks | where: 'type', 'member' %}
{% if team_blocks.size > 0 %}
<section class="about-team">
  <div class="about-eyebrow">{{ section.settings.team_eyebrow }}</div>
  <h2 class="about-h2">{{ section.settings.team_heading }}</h2>
  <p class="about-sub">{{ section.settings.team_sub }}</p>
  <div class="about-team__grid">
    {% for block in section.blocks %}
      {% if block.type == 'member' %}
        <div class="about-team__card" {{ block.shopify_attributes }}>
          <div class="about-team__avatar">{{ block.settings.initials }}</div>
          <div class="about-team__name">{{ block.settings.name }}</div>
          <div class="about-team__role">{{ block.settings.role }}</div>
          <div class="about-team__bio">{{ block.settings.bio }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% comment %} ── 6. Timeline ─────────────────────── {% endcomment %}
{% assign tl_blocks = section.blocks | where: 'type', 'milestone' %}
{% if tl_blocks.size > 0 %}
<section class="about-timeline">
  <div style="text-align:center; position:relative; z-index:1;">
    <div class="about-eyebrow">{{ section.settings.tl_eyebrow }}</div>
    <h2 class="about-h2">{{ section.settings.tl_heading }}</h2>
    <p class="about-sub">{{ section.settings.tl_sub }}</p>
  </div>
  <div class="about-tl" style="position:relative; z-index:1;">
    {% for block in section.blocks %}
      {% if block.type == 'milestone' %}
        <div class="about-tl__item {% if block.settings.align_right %}right{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.align_right %}<div class="about-tl__spacer"></div>{% endif %}
          {% unless block.settings.align_right %}
            <div class="about-tl__content">
              <div class="about-tl__year">{{ block.settings.year }}</div>
              <div class="about-tl__desc">{{ block.settings.desc }}</div>
            </div>
            <div class="about-tl__dot"></div>
            <div class="about-tl__spacer"></div>
          {% else %}
            <div class="about-tl__dot"></div>
            <div class="about-tl__content">
              <div class="about-tl__year">{{ block.settings.year }}</div>
              <div class="about-tl__desc">{{ block.settings.desc }}</div>
            </div>
          {% endunless %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

<script>
(function(){
  var tl = document.querySelector('.about-tl');
  if (!tl || !('IntersectionObserver' in window)) return;
  tl.classList.add('reveal-on');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });
  tl.querySelectorAll('.about-tl__item').forEach(function(item){ io.observe(item); });
})();
</script>

{% schema %}
{
  "name": "Vamas About",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "WHO WE ARE" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Our Story" },
    { "type": "textarea", "id": "hero_sub", "label": "Subtext", "default": "Born from a love of Indian craftsmanship, woven with tradition, worn with pride." },
    { "type": "header", "content": "Brand Story" },
    { "type": "text", "id": "story_eyebrow", "label": "Eyebrow", "default": "THE VAMAS STORY" },
    { "type": "richtext", "id": "story_heading", "label": "Heading", "default": "<p>Every blouse tells<br><em>a story.</em></p>" },
    { "type": "richtext", "id": "story_body", "label": "Body", "default": "<p>Founded with a deep love for Indian craftsmanship, Vamas was born from a simple belief — every woman deserves a blouse that tells her story. We work directly with skilled karigars across India to bring you heirloom-quality pieces at honest prices.</p><p>Our name, Vamas, is rooted in the Sanskrit tradition — it means \"beautiful\" and \"belonging to the left side,\" a sacred direction in Indian culture. Each stitch we make is a tribute to the artisans whose hands carry centuries of knowledge.</p><p>From the looms of Varanasi to the block-print studios of Jaipur, every Vamas blouse is a journey across India's rich textile heritage.</p>" },
    { "type": "image_picker", "id": "story_image", "label": "Story Image" },
    { "type": "text", "id": "story_image_asset", "label": "Or theme asset filename", "info": "e.g. slide-pink.jpg", "default": "slide-pink.jpg" },
    { "type": "header", "content": "Values Section" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "WHAT WE STAND FOR" },
    { "type": "text", "id": "values_heading", "label": "Heading", "default": "Our Values" },
    { "type": "textarea", "id": "values_sub", "label": "Subtext", "default": "Three principles guide everything we create, from the studio to your wardrobe." },
    { "type": "header", "content": "Team Section" },
    { "type": "text", "id": "team_eyebrow", "label": "Eyebrow", "default": "THE PEOPLE BEHIND VAMAS" },
    { "type": "text", "id": "team_heading", "label": "Heading", "default": "Meet Our Team" },
    { "type": "textarea", "id": "team_sub", "label": "Subtext", "default": "Passionate individuals united by a love for Indian textiles and a mission to celebrate our artisans." },
    { "type": "header", "content": "Timeline Section" },
    { "type": "text", "id": "tl_eyebrow", "label": "Eyebrow", "default": "OUR JOURNEY" },
    { "type": "text", "id": "tl_heading", "label": "Heading", "default": "Milestones That Define Us" },
    { "type": "textarea", "id": "tl_sub", "label": "Subtext", "default": "From a small Jaipur studio to India's trusted blouse brand — here is how we grew." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "stat_num", "label": "Number", "default": "10,000+" },
        { "type": "text", "id": "stat_label", "label": "Label", "default": "Happy Customers" }
      ]
    },
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "craft", "options": [
          { "value": "craft", "label": "Star (Craftsmanship)" },
          { "value": "sustain", "label": "Leaf (Sustainability)" },
          { "value": "authentic", "label": "Home (Authenticity)" }
        ] },
        { "type": "text", "id": "title", "label": "Title", "default": "Craftsmanship" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "Every piece is handmade with care by master karigars. No shortcuts, no compromises — only the finest finishing that stands the test of time." }
      ]
    },
    {
      "type": "member",
      "name": "Team Member",
      "settings": [
        { "type": "text", "id": "initials", "label": "Initials", "default": "MS" },
        { "type": "text", "id": "name", "label": "Name", "default": "Meera Sharma" },
        { "type": "text", "id": "role", "label": "Role", "default": "Founder" },
        { "type": "textarea", "id": "bio", "label": "Bio", "default": "Visionary behind Vamas, passionate about preserving Indian textile heritage." }
      ]
    },
    {
      "type": "milestone",
      "name": "Timeline Milestone",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "2018" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "Founded in Jaipur with just 10 designs and a single karigar workshop." },
        { "type": "checkbox", "id": "align_right", "label": "Align right", "default": false }
      ]
    }
  ],
  "presets": [
    { "name": "Vamas About" }
  ]
}
{% endschema %}
