{% comment %} ── Announcement Bar ─────────────────── {% endcomment %}
{% if section.settings.show_announce %}
{% if section.settings.announce_marquee %}
<div class="vamas-announce vamas-announce--marquee">
  <div class="vamas-announce__track" style="animation-duration: {{ section.settings.announce_speed | default: 22 }}s;">
    <span>{{ section.settings.announce_text }}</span>
    <span aria-hidden="true">{{ section.settings.announce_text }}</span>
  </div>
</div>
{% else %}
<div class="vamas-announce">{{ section.settings.announce_text }}</div>
{% endif %}
{% endif %}

<div class="vamas-nav-wrapper" id="vamas-nav-wrapper">
  <nav class="vamas-nav-outer">
    <div class="vamas-nav">
      <a href="{{ routes.root_url }}" class="vamas-nav__logo">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" class="vamas-nav__logo-img" width="120" height="42">
        {% elsif section.settings.logo_asset != blank %}
          <img src="{{ section.settings.logo_asset | asset_url }}" alt="{{ shop.name }}" class="vamas-nav__logo-img" width="120" height="42">
        {% else %}
          <span class="vamas-nav__brand">{{ shop.name }}</span>
        {% endif %}
      </a>

      <div class="vamas-nav__links">
        {% for link in section.settings.main_menu.links %}
          <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title | upcase }}</a>
        {% endfor %}
      </div>

      <div class="vamas-nav__icons">
        <a href="{{ routes.search_url }}" id="vamas-search-toggle" title="Search" aria-label="Search">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
        <a href="{{ section.settings.wishlist_url | default: '/pages/wishlist' }}" title="Wishlist" aria-label="Wishlist" style="position:relative;">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="vamas-cart-badge" id="vamas-nav-wish-badge" style="display:none;">0</span>
        </a>
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" title="Account" aria-label="Account">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <a href="{{ routes.cart_url }}" id="vamas-nav-cart-link" title="Cart" aria-label="Cart" style="position:relative;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span class="vamas-cart-badge" id="vamas-nav-cart-badge" {% if cart.item_count == 0 %}style="display:none;"{% endif %}>{{ cart.item_count }}</span>
        </a>
        <a href="{{ section.settings.contact_url | default: '/pages/contact' }}" class="vamas-nav__contact-btn">{{ section.settings.contact_label | default: 'Contact Us' }}</a>
        <button class="vamas-nav__hamburger" id="vamas-nav-hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
      </div>
    </div>
  </nav>

  <div class="vamas-nav__mobile-menu" id="vamas-nav-mobile-menu">
    {% for link in section.settings.main_menu.links %}
      <a href="{{ link.url }}">{{ link.title | upcase }}</a>
    {% endfor %}
  </div>
</div>

<div class="vamas-search-overlay" id="vamas-search-overlay">
  <form class="vamas-search-box" action="{{ routes.search_url }}" method="get" role="search">
    <svg class="vamas-search-box__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="search" name="q" placeholder="Search for blouses, fabrics, occasions…" autocomplete="off" aria-label="Search">
    <button type="submit" class="vamas-search-box__submit">SEARCH</button>
    <button type="button" class="vamas-search-box__close" id="vamas-search-close" aria-label="Close search">&times;</button>
  </form>
</div>

<script>
(function(){
  var wrap = document.getElementById('vamas-nav-wrapper');
  var btn = document.getElementById('vamas-nav-hamburger');
  if (btn) {
    btn.addEventListener('click', function(){
      wrap.classList.toggle('vamas-nav-mobile-open');
    });
  }
  var toggle = document.getElementById('vamas-search-toggle');
  var overlay = document.getElementById('vamas-search-overlay');
  var close = document.getElementById('vamas-search-close');
  function openSearch(e){ if(e) e.preventDefault(); overlay.classList.add('open'); var i = overlay.querySelector('input'); if(i){ setTimeout(function(){ i.focus(); }, 50); } }
  function closeSearch(){ overlay.classList.remove('open'); }
  if (toggle && overlay) { toggle.addEventListener('click', openSearch); }
  if (close) { close.addEventListener('click', closeSearch); }
  if (overlay) { overlay.addEventListener('click', function(e){ if(e.target === overlay) closeSearch(); }); }
  document.addEventListener('keydown', function(e){ if(e.key === 'Escape' && overlay) closeSearch(); });
})();
</script>

{% schema %}
{
  "name": "Vamas Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "logo_asset", "label": "Or theme asset filename", "info": "e.g. vamas-logo.avif", "default": "vamas-logo.avif" },
    { "type": "link_list", "id": "main_menu", "label": "Navigation Menu", "default": "main-menu" },
    { "type": "header", "content": "Contact Button" },
    { "type": "text", "id": "contact_label", "label": "Button Text", "default": "Contact Us" },
    { "type": "url", "id": "contact_url", "label": "Button URL" },
    { "type": "url", "id": "wishlist_url", "label": "Wishlist URL" },
    { "type": "header", "content": "Announcement Bar" },
    { "type": "checkbox", "id": "show_announce", "label": "Show Announcement Bar", "default": true },
    { "type": "checkbox", "id": "announce_marquee", "label": "Scrolling Marquee (start/stop)", "info": "On = text scrolls in a loop. Off = static.", "default": false },
    { "type": "range", "id": "announce_speed", "min": 8, "max": 40, "step": 2, "unit": "s", "label": "Marquee Speed (seconds per loop)", "default": 22 },
    { "type": "text", "id": "announce_text", "label": "Announcement Text", "default": "✦ FREE SHIPPING ABOVE ₹999  |  USE CODE FIRST10 FOR 10% OFF  |  NEW BRIDAL COLLECTION NOW LIVE ✦" }
  ],
  "presets": [{ "name": "Vamas Header" }]
}
{% endschema %}
