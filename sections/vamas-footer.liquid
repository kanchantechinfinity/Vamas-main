{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% if section.settings.show_faq %}
<section class="vamas-faq">
  <div class="vamas-faq__inner">
    <div class="vamas-faq__eye">GOT QUESTIONS?</div>
    <h2 class="vamas-faq__heading">Frequently Asked <span>Questions</span></h2>
    <div class="vamas-faq__list">
      <div class="vamas-faq__item">
        <button type="button" class="vamas-faq__q">How long does delivery take?<span class="vamas-faq__chev" aria-hidden="true">&#8250;</span></button>
        <div class="vamas-faq__a"><p>We deliver pan-India within 3-5 business days. For remote areas, 7-10 business days.</p></div>
      </div>
      <div class="vamas-faq__item">
        <button type="button" class="vamas-faq__q">Do you offer custom sizing?<span class="vamas-faq__chev" aria-hidden="true">&#8250;</span></button>
        <div class="vamas-faq__a"><p>Yes! Custom sizing at no extra charge — share measurements in order notes at checkout.</p></div>
      </div>
      <div class="vamas-faq__item">
        <button type="button" class="vamas-faq__q">What is your return policy?<span class="vamas-faq__chev" aria-hidden="true">&#8250;</span></button>
        <div class="vamas-faq__a"><p>7-day hassle-free returns on unworn items in original condition with tags intact.</p></div>
      </div>
      <div class="vamas-faq__item">
        <button type="button" class="vamas-faq__q">How can I track my order?<span class="vamas-faq__chev" aria-hidden="true">&#8250;</span></button>
        <div class="vamas-faq__a"><p>A tracking link is sent via SMS and email once your order is dispatched.</p></div>
      </div>
      <div class="vamas-faq__item">
        <button type="button" class="vamas-faq__q">Do you offer wholesale?<span class="vamas-faq__chev" aria-hidden="true">&#8250;</span></button>
        <div class="vamas-faq__a"><p>Yes, for orders above 50 pieces. Write to wholesale@vamas.in for our bulk pricing catalog.</p></div>
      </div>
    </div>
  </div>
</section>
{% endif %}

<footer class="vamas-footer">

  {% if section.settings.show_newsletter %}
  <div class="vamas-footer__newsletter">
    <div class="vamas-footer__nl-eye">EXCLUSIVE UPDATES</div>
    <h2 class="vamas-footer__nl-heading">Stay in <em>style.</em></h2>
    <p class="vamas-footer__nl-sub">Subscribe for new arrivals, exclusive offers &amp; style inspiration</p>
    {% form 'customer', id: 'vamas-footer-nl' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="vamas-footer__nl-form">
        <input class="vamas-footer__nl-input" type="email" name="contact[email]" placeholder="Enter your email address" required>
        <button type="submit" class="vamas-footer__nl-btn">SUBSCRIBE</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="vamas-footer__nl-success">Thank you for subscribing! ✦</p>
      {% endif %}
    {% endform %}
  </div>
  {% endif %}

  {% if section.settings.show_shop_links %}
  <div class="vamas-shopby">
    {% assign shopby_cat = "Sarees | Kurtas for Women | Short Kurtas for Women | Blouse | Kurta Sets for Women | Co-Ord Sets | Dress Materials | Suits for Women | Tunics | Dresses for Women | Kaftans | Shrugs | Ethnic Gowns | Jumpsuits | Lehenga | Chudidars | Dupatta | Petticoats | Pants | Palazzos | Sharara Suits | Anarkali Suits | Kurta Pant Sets | Palazzo Kurta Sets | Dhoti Sets | Collar Kurtas and Sets | Punjabi Suits | Sleeveless Kurta Sets | Indo-Western Wear for Women | Lehenga Choli for Women | Crop Top Lehenga | Long Dresses" | split: "|" %}
    <div class="vamas-shopby__group">
      <div class="vamas-shopby__title">Shop By Category</div>
      <div class="vamas-shopby__links">
        {% for item in shopby_cat %}<a href="/collections/{{ item | strip | handleize }}">{{ item | strip }}</a>{% endfor %}
      </div>
    </div>

    {% assign shopby_fest = "Diwali | Karwa Chauth | Bhai Dooj Special | Onam | Rakhi Collection | Navratri | Dussehra | Durga Pujo | The Festival of Lohri and Sankranti | Pongal | Holi | Ugadi and Gudi Padwa | Christmas | Ramadan & Eid | Ganesh Chaturthi" | split: "|" %}
    <div class="vamas-shopby__group">
      <div class="vamas-shopby__title">Shop By Festival</div>
      <div class="vamas-shopby__links">
        {% for item in shopby_fest %}<a href="/collections/{{ item | strip | handleize }}">{{ item | strip }}</a>{% endfor %}
      </div>
    </div>

    {% assign shopby_occ = "Wedding Dresses for Women | Wedding Guest Outfits | Bridesmaid Dresses | Mehendi Outfits | Sangeet Dresses | Haldi Ready Dresses | Reception Outfits | Party Wear Dresses for Women | Engagement Dresses | Autumn Outfits | Festive Edit | Bridal Lehenga | Kasavu Sarees | Colors of Freedom | Valentine Day | Women's Day Special | Summer Outfits | Black Friday | Office Work Wear | Monsoon Edit | Winter Outfits" | split: "|" %}
    <div class="vamas-shopby__group">
      <div class="vamas-shopby__title">Shop By Occasion</div>
      <div class="vamas-shopby__links">
        {% for item in shopby_occ %}<a href="/collections/{{ item | strip | handleize }}">{{ item | strip }}</a>{% endfor %}
      </div>
    </div>

    {% assign shopby_trend = "Purple and Lavender Collection | Embroidered Outfits | Fendi Suits | Black Ethnic Dresses | Fendi Sarees | Red Ethnic Dresses | Green Ethnic Wear | Vivid Blooms | Tales of Tissue | Simply Solids | Linen Loom | Gypsy Ink - Bohemian Inspired Collection | Bandhej Treasures | Print Perfection | Pastel Harmony | Kalamkari Chronicles | Baroque Collection | Ivory Elegance | Floral Drifts | Glimmer Glam | Muse of Mirror | Black Sarees | Our Top Picks | Evergreen Anarkali | Chikankari Collection | Kota Couture" | split: "|" %}
    <div class="vamas-shopby__group">
      <div class="vamas-shopby__title">Top Trendsetter's Collection</div>
      <div class="vamas-shopby__links">
        {% for item in shopby_trend %}<a href="/collections/{{ item | strip | handleize }}">{{ item | strip }}</a>{% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

  <div class="vamas-footer__grid">

    <div>
      <div class="vamas-footer__logo">
        <img src="{{ 'vamas-logo.avif' | asset_url }}" alt="{{ section.settings.brand_name | default: 'Vamas' }} Logo" class="vamas-footer__logo-img">
      </div>
      <p class="vamas-footer__desc">{{ section.settings.brand_desc }}</p>
      <div class="vamas-footer__socials">
        {% if section.settings.instagram != blank %}
          <a href="{{ section.settings.instagram }}" class="vamas-footer__social" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
        {% if section.settings.facebook != blank %}
          <a href="{{ section.settings.facebook }}" class="vamas-footer__social" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.whatsapp != blank %}
          <a href="https://wa.me/{{ section.settings.whatsapp }}" class="vamas-footer__social" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">QUICK LINKS</div>
      <div class="vamas-footer__links">
        <a href="/collections/all">New Arrivals</a>
        <a href="/collections/all">All Collections</a>
        <a href="/collections/all">Best Sellers</a>
        <a href="/pages/about">About Us</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">CUSTOMER CARE</div>
      <div class="vamas-footer__links">
        <a href="#" id="vamas-size-guide-link">Size Guide</a>
        <a href="{{ routes.account_url }}">Track Order</a>
        <a href="{{ shop.refund_policy.url | default: '/pages/contact' }}">Returns &amp; Exchange</a>
        <a href="/pages/contact#faq">FAQ</a>
        <a href="{{ shop.shipping_policy.url | default: '/pages/contact' }}">Shipping Policy</a>
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">CONTACT US</div>
      <div class="vamas-footer__links">
        {% if section.settings.contact_email != blank %}
          <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
        {% endif %}
        {% if section.settings.contact_phone != blank %}
          <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
        {% endif %}
        {% if section.settings.contact_hours != blank %}
          <span style="color:rgba(231,209,166,0.4);font-size:11px;">{{ section.settings.contact_hours }}</span>
        {% endif %}
      </div>
    </div>

  </div>

  <div class="vamas-footer__bottom">
    <div class="vamas-footer__copy">© {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.</div>
    <div class="vamas-footer__payments">
      <span class="vamas-footer__payment-icon" style="font-size:11px;color:rgba(231,209,166,0.5);">UPI &nbsp;|&nbsp; Cards &nbsp;|&nbsp; Net Banking &nbsp;|&nbsp; COD</span>
    </div>
  </div>
</footer>

<div class="vamas-sizeguide-overlay" id="vamas-sizeguide">
  <div class="vamas-sizeguide">
    <button type="button" class="vamas-sizeguide__close" id="vamas-sizeguide-close" aria-label="Close">&times;</button>
    <div class="vamas-sizeguide__title">Size Guide</div>
    <div class="vamas-sizeguide__sub">All measurements in inches. For a custom fit, add your measurements in the order notes at checkout.</div>
    <div class="vamas-sizeguide__scroll">
      <table class="vamas-sizeguide__table">
        <thead>
          <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Shoulder</th><th>Length</th></tr>
        </thead>
        <tbody>
          <tr><td>32</td><td>32</td><td>26</td><td>13</td><td>14.5</td></tr>
          <tr><td>34</td><td>34</td><td>28</td><td>13.5</td><td>15</td></tr>
          <tr><td>36</td><td>36</td><td>30</td><td>14</td><td>15.5</td></tr>
          <tr><td>38</td><td>38</td><td>32</td><td>14.5</td><td>15.5</td></tr>
          <tr><td>40</td><td>40</td><td>34</td><td>15</td><td>16</td></tr>
          <tr><td>42</td><td>42</td><td>36</td><td>15.5</td><td>16</td></tr>
        </tbody>
      </table>
    </div>
    <div class="vamas-sizeguide__note">Tip: Measure a well-fitting blouse and match it to the chart. When between sizes, choose the larger.</div>
  </div>
</div>

<style>
  .vamas-sizeguide-overlay { position: fixed; inset: 0; z-index: 3000; background: rgba(42,0,1,0.6); backdrop-filter: blur(3px); display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; visibility: hidden; transition: opacity 0.25s, visibility 0.25s; }
  .vamas-sizeguide-overlay.open { opacity: 1; visibility: visible; }
  .vamas-sizeguide { position: relative; background: #fff; border-radius: 16px; padding: 32px; width: min(520px, 94vw); box-shadow: 0 24px 64px rgba(0,0,0,0.3); transform: translateY(-12px); transition: transform 0.25s; }
  .vamas-sizeguide-overlay.open .vamas-sizeguide { transform: translateY(0); }
  .vamas-sizeguide__close { position: absolute; top: 14px; right: 16px; background: none; border: none; font-size: 26px; line-height: 1; color: rgba(66,0,1,0.5); cursor: pointer; }
  .vamas-sizeguide__close:hover { color: var(--color-maroon); }
  .vamas-sizeguide__title { font-family: var(--font-heading); font-size: 26px; font-weight: 700; color: var(--color-maroon); margin-bottom: 6px; }
  .vamas-sizeguide__sub { font-size: 12px; color: rgba(66,0,1,0.55); margin-bottom: 20px; line-height: 1.6; }
  .vamas-sizeguide__scroll { overflow-x: auto; }
  .vamas-sizeguide__table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .vamas-sizeguide__table th { background: var(--color-maroon); color: var(--color-gold); padding: 10px; font-weight: 700; text-align: center; }
  .vamas-sizeguide__table th:first-child { border-top-left-radius: 8px; }
  .vamas-sizeguide__table th:last-child { border-top-right-radius: 8px; }
  .vamas-sizeguide__table td { padding: 9px 10px; text-align: center; border-bottom: 1px solid rgba(66,0,1,0.08); color: rgba(66,0,1,0.75); }
  .vamas-sizeguide__table tbody tr:nth-child(even) { background: var(--color-bg); }
  .vamas-sizeguide__note { margin-top: 16px; font-size: 12px; color: rgba(66,0,1,0.6); line-height: 1.6; }

  /* Shop By mega links */
  .vamas-shopby { max-width: 1280px; margin: 0 auto; padding: 8px var(--page-gutter) 32px; border-bottom: 1px solid rgba(231,209,166,0.18); }
  .vamas-shopby__group { padding: 16px 0; border-top: 1px solid rgba(231,209,166,0.12); }
  .vamas-shopby__group:first-child { border-top: none; }
  .vamas-shopby__title { font-family: var(--font-heading); color: var(--color-gold); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 10px; }
  .vamas-shopby__links { display: flex; flex-wrap: wrap; align-items: center; gap: 4px 0; }
  .vamas-shopby__links a { font-family: var(--font-body); font-size: 12px; color: rgba(231,209,166,0.6); text-decoration: none; padding: 2px 10px; line-height: 1.4; border-right: 1px solid rgba(231,209,166,0.22); transition: color 0.2s; }
  .vamas-shopby__links a:first-child { padding-left: 0; }
  .vamas-shopby__links a:last-child { border-right: none; }
  .vamas-shopby__links a:hover { color: var(--color-gold); }

  /* FAQ accordion */
  .vamas-faq { background: var(--color-bg); }
  .vamas-faq__inner { max-width: 820px; margin: 0 auto; padding: 56px var(--page-gutter); }
  .vamas-faq__eye { font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.18em; color: var(--color-gold-dark); text-align: center; margin-bottom: 10px; }
  .vamas-faq__heading { font-family: var(--font-heading); font-size: clamp(26px, 4vw, 38px); font-weight: 700; color: var(--color-maroon); text-align: center; margin: 0 0 32px; }
  .vamas-faq__heading span { color: var(--color-gold-dark); }
  .vamas-faq__item { border-bottom: 1px solid rgba(66,0,1,0.1); }
  .vamas-faq__q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; background: none; border: none; cursor: pointer; text-align: left; padding: 20px 4px; font-family: var(--font-heading); font-size: 17px; font-weight: 600; color: var(--color-maroon); }
  .vamas-faq__chev { font-size: 24px; line-height: 1; color: var(--color-gold-dark); transition: transform 0.3s; transform: rotate(90deg); flex-shrink: 0; }
  .vamas-faq__item.open .vamas-faq__chev { transform: rotate(-90deg); }
  .vamas-faq__a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .vamas-faq__item.open .vamas-faq__a { max-height: 240px; }
  .vamas-faq__a p { margin: 0; padding: 0 4px 20px; font-family: var(--font-body); font-size: 14px; line-height: 1.7; color: rgba(66,0,1,0.7); }
</style>

<script>
(function(){
  var overlay = document.getElementById('vamas-sizeguide');
  var open = document.getElementById('vamas-size-guide-link');
  var close = document.getElementById('vamas-sizeguide-close');
  if (open && overlay) { open.addEventListener('click', function(e){ e.preventDefault(); overlay.classList.add('open'); }); }
  if (close) { close.addEventListener('click', function(){ overlay.classList.remove('open'); }); }
  if (overlay) { overlay.addEventListener('click', function(e){ if(e.target === overlay) overlay.classList.remove('open'); }); }
  document.addEventListener('keydown', function(e){ if(e.key === 'Escape' && overlay) overlay.classList.remove('open'); });
})();

(function(){
  var items = document.querySelectorAll('.vamas-faq__item');
  items.forEach(function(item){
    var btn = item.querySelector('.vamas-faq__q');
    if (!btn) return;
    btn.addEventListener('click', function(){
      var isOpen = item.classList.contains('open');
      items.forEach(function(o){ o.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
    });
  });
})();
</script>

{% schema %}
{
  "name": "Vamas Footer",
  "settings": [
    { "type": "checkbox", "id": "show_newsletter", "label": "Show Newsletter", "default": true },
    { "type": "checkbox", "id": "show_shop_links", "label": "Show Shop By Links", "default": true },
    { "type": "checkbox", "id": "show_faq", "label": "Show FAQ Accordion", "default": true },
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "VAMAS" },
    { "type": "textarea", "id": "brand_desc", "label": "Brand Description", "default": "Premium handcrafted blouses celebrating Indian artistry and elegance. Every piece tells a story." },
    { "type": "header", "content": "Social Links" },
    { "type": "text", "id": "instagram", "label": "Instagram URL" },
    { "type": "text", "id": "facebook", "label": "Facebook URL" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp Number (with country code)", "placeholder": "919876543210" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "contact_email", "label": "Email" },
    { "type": "text", "id": "contact_phone", "label": "Phone" },
    { "type": "text", "id": "contact_hours", "label": "Support Hours", "default": "Mon–Sat: 10am – 6pm" }
  ],
  "presets": [{ "name": "Vamas Footer" }]
}
{% endschema %}
