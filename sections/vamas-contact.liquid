{{ 'vamas-contact.css' | asset_url | stylesheet_tag }}

<section class="contact-hero">
  <div class="hero-eye">{{ section.settings.eyebrow | default: shop.name | upcase }}</div>
  <h1 class="hero-title">{{ section.settings.heading | default: 'Get In Touch' }}</h1>
  <p class="hero-sub">{{ section.settings.subheading | default: "We'd love to hear from you" }}</p>
</section>

<section class="contact-sec">
  <div class="contact-grid">
    <div class="form-wrap">
      <div class="form-title">{{ section.settings.form_title | default: 'Send Us a Message' }}</div>
      <div class="form-sub">{{ section.settings.form_subtitle | default: "Fill in the form and we'll get back to you shortly." }}</div>

      {% form 'contact', id: 'contactForm' %}
        {% if form.posted_successfully? %}
          <div class="form-success" style="display:block;">Thank you! We'll get back to you within 24 hours.</div>
        {% endif %}
        {% if form.errors %}
          <div class="form-success" style="display:block;background:#fdecea;color:#c62828;">{{ form.errors | default_errors }}</div>
        {% endif %}
        <div class="form-group">
          <label for="fname">FULL NAME</label>
          <input type="text" id="fname" name="contact[name]" placeholder="Your full name" required>
        </div>
        <div class="form-group">
          <label for="femail">EMAIL ADDRESS</label>
          <input type="email" id="femail" name="contact[email]" value="{{ form.email }}" placeholder="your@email.com" required>
        </div>
        <div class="form-group">
          <label for="fphone">PHONE NUMBER</label>
          <input type="tel" id="fphone" name="contact[phone]" placeholder="+91 XXXXX XXXXX">
        </div>
        <div class="form-group">
          <label for="fsubject">SUBJECT</label>
          <select id="fsubject" name="contact[subject]">
            <option value="" disabled selected>Select a subject</option>
            <option value="general">General Inquiry</option>
            <option value="order">Order Issue</option>
            <option value="custom">Custom Order</option>
            <option value="wholesale">Wholesale</option>
          </select>
        </div>
        <div class="form-group">
          <label for="fmessage">MESSAGE</label>
          <textarea id="fmessage" name="contact[body]" rows="5" placeholder="Tell us how we can help you..." required></textarea>
        </div>
        <button type="submit" class="btn-submit">SEND MESSAGE</button>
      {% endform %}
    </div>

    <div class="info-cards">
      {% for block in section.blocks %}
        {% if block.type == 'info_card' %}
        <div class="info-card">
          <div class="info-icon">{{ block.settings.icon_svg }}</div>
          <div class="info-head">{{ block.settings.heading }}</div>
          <div class="info-line">{{ block.settings.text }}</div>
          {% if block.settings.show_social %}
          <div class="social-row">
            {% if settings.social_instagram != blank %}<a href="{{ settings.social_instagram }}" class="soc-btn" title="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{% endif %}
            {% if settings.social_facebook != blank %}<a href="{{ settings.social_facebook }}" class="soc-btn" title="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
            {% if settings.whatsapp_number != blank %}<a href="https://wa.me/{{ settings.whatsapp_number }}" class="soc-btn" title="WhatsApp"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></a>{% endif %}
          </div>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
{% if faq_blocks.size > 0 %}
<section class="faq-sec">
  <div class="sec-hdr-c">
    <div class="sec-eye">{{ section.settings.faq_eyebrow | default: 'GOT QUESTIONS?' }}</div>
    <div class="sec-title-c">{{ section.settings.faq_heading | default: 'Frequently Asked Questions' }}</div>
    <div class="sec-sub-c">{{ section.settings.faq_subheading | default: 'Quick answers to what our customers ask most' }}</div>
  </div>
  <div class="faq-list">
    {% for block in faq_blocks %}
    <div class="faq-item">
      <button class="faq-q" type="button">
        {{ block.settings.question }}
        <span class="faq-arrow"><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
      </button>
      <div class="faq-a">{{ block.settings.answer }}</div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if section.settings.show_map %}
<section class="map-sec">
  <div class="map-inner">
    <div class="map-placeholder">
      <div class="map-pin-wrap"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
      <div class="map-label">Find Us</div>
      <div class="map-addr">{{ section.settings.map_address }}</div>
    </div>
  </div>
</section>
{% endif %}

<script>
(function(){
  document.querySelectorAll('.faq-q').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = btn.closest('.faq-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('open'); });
      if(!isOpen){ item.classList.add('open'); }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Vamas Contact",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get In Touch" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We'd love to hear from you" },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "form_title", "label": "Form Title", "default": "Send Us a Message" },
    { "type": "text", "id": "form_subtitle", "label": "Form Subtitle" },
    { "type": "header", "content": "FAQ Section" },
    { "type": "text", "id": "faq_eyebrow", "label": "FAQ Eyebrow", "default": "GOT QUESTIONS?" },
    { "type": "text", "id": "faq_heading", "label": "FAQ Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "faq_subheading", "label": "FAQ Subheading" },
    { "type": "header", "content": "Map" },
    { "type": "checkbox", "id": "show_map", "label": "Show Map Section", "default": true },
    { "type": "text", "id": "map_address", "label": "Address", "default": "123, Artisan Lane, Jaipur, Rajasthan 302001" }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon (SVG code)", "default": "<svg viewBox=\"0 0 24 24\"><path d=\"M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "OUR STUDIO" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "checkbox", "id": "show_social", "label": "Show Social Icons", "default": false }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does delivery take?" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vamas Contact",
      "blocks": [
        { "type": "info_card", "settings": { "heading": "OUR STUDIO" } },
        { "type": "info_card", "settings": { "heading": "CALL US" } },
        { "type": "info_card", "settings": { "heading": "EMAIL US" } },
        { "type": "info_card", "settings": { "heading": "FOLLOW US", "show_social": true } },
        { "type": "faq", "settings": { "question": "How long does delivery take?", "answer": "<p>We deliver pan-India within 3-5 business days.</p>" } },
        { "type": "faq", "settings": { "question": "Do you offer custom sizing?", "answer": "<p>Yes! Share your measurements in the order notes at checkout.</p>" } },
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "<p>7-day hassle-free returns on unworn items with tags intact.</p>" } }
      ]
    }
  ]
}
{% endschema %}
